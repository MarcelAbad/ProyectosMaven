<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      stylesheets="/styles/styles.css"
      fx:controller="dam.code.controller.RegistroController"
      spacing="15"
      alignment="CENTER"
      styleClass="root-container"
      prefWidth="400" prefHeight="500">

    <Label text="Registro de Usuario" styleClass="title2"/>

    <VBox spacing="8" styleClass="hbox">

        <Label text="DNI (8 números y 1 letra)"/>
        <TextField fx:id="txtDni" promptText="12345678A"/>

        <Label text="Nombre"/>
        <TextField fx:id="txtNombre" promptText="Nombre"/>

        <Label text="Apellido"/>
        <TextField fx:id="txtApellido" promptText="Apellido"/>

        <Label text="Email"/>
        <TextField fx:id="txtEmail" promptText="correo@ejemplo.com"/>

        <Label text="Contraseña"/>
        <PasswordField fx:id="txtContrasena" promptText="Contraseña"/>

    </VBox>

    <VBox spacing="8" styleClass="hbox">
        <Button text="Registrarse"
                onAction="#registrar"
                styleClass="button"
                maxWidth="Infinity"/>

        <Button text="¿Ya tienes cuenta? Inicia sesión"
                onAction="#irInicio"
                styleClass="btn-secondary"
                maxWidth="Infinity"/>
    </VBox>

</VBox>